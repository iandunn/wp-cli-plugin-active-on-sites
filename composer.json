{
	"name"        : "iandunn/wp-cli-plugin-active-on-sites",
	"description" : "A WP-CLI command to list all sites in a Multisite network that have activated a given plugin",
	"type"        : "wordpress-plugin",
	"homepage"    : "https://github.com/iandunn/wp-cli-plugin-active-on-sites",
	"license"     : "GPLv2",

	"keywords" : [ "wp-cli", "wordpress", "multisite", "plugins" ],

	"support" : {
		"issues" : "https://github.com/iandunn/wp-cli-plugin-active-on-sites/issues",
		"source"  : "https://github.com/iandunn/wp-cli-plugin-active-on-sites"
	},

	"authors" : [
		{
			"name"     : "Ian Dunn",
			"email"    : "ian@iandunn.name",
			"homepage" : "https://iandunn.name"
		}
	],

	"autoload" : {
		"files" : [ "wp-cli-plugin-active-on-sites.php" ]
	},

	"require-dev" : {
		"wp-cli/wp-cli-tests"      : "^4.2",
		"wp-cli/extension-command" : "^2",
		"wp-cli/entity-command"    : "^2"
	},

	"scripts" : {
		"test"          : [
			"Composer\\Config::disableProcessTimeout",
			"bin/test"
		],
		"test-rerun"    : [
			"Composer\\Config::disableProcessTimeout",
			"bin/test --rerun"
		],
		"prepare-tests" : "install-package-tests"
	},

	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
